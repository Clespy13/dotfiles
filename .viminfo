"8	CHAR	0
	
	void list_insert_sort(struct list *list)
	{
	    if (list_is_empty(list))
	        return;
	
	    struct list fake_head = { 0, 0 };
	
	    while (!list_is_empty(list))
	    {
	        struct list *elm = list_pop_front(list);
	        list_insert(&fake_head, elm);
	    }
	
	    list->next = fake_head.next;
	}
	
	
